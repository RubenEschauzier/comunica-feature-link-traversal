{
  "@context": [
    "https://linkedsoftwaredependencies.org/bundles/npm/@comunica/runner/^5.0.0/components/context.jsonld",

    "https://linkedsoftwaredependencies.org/bundles/npm/@comunica/actor-context-preprocess-set-cache-source-state/^0.0.0/components/context.jsonld",
    "https://linkedsoftwaredependencies.org/bundles/npm/@comunica/actor-context-preprocess-set-persistent-cache-manager/^5.0.0/components/context.jsonld"
  ],
  "@id": "urn:comunica:default:Runner",
  "@type": "Runner",
  "actors": [
    {
      "@id": "urn:comunica:default:context-preprocess/actors#set-cache-source-state",
      "@type": "ActorContextPreprocessSetCacheSourceState",
      "mediatorQuerySourceIdentifyHypermedia": { "@id": "urn:comunica:default:query-source-identify-hypermedia/mediators#main" },
      "cacheSizeNumTriples": 1000000,
      "probabilityCacheMiss": 0.7,
      "actorExtractLinksQuadPatternQuery": { "@id": "urn:comunica:default:extract-links/actors#quad-pattern-query" }
    },
    {
      "@id": "urn:comunica:default:context-preprocess/actors#set-persistent-cache-manager",
      "@type": "ActorContextPreprocessSetPersistentCacheManager",
      "trackCacheMetrics": true,
      "beforeActors": { "@id": "urn:comunica:default:context-preprocess/actors#set-cache-source-state" }
    }
  ]
}
